NEXT_PUBLIC_APP_URL=http://localhost:3000

# Prisma application/runtime URL.
# Local development default: use the Supabase session pooler on port 5432.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres?sslmode=require&connect_timeout=30

# Prisma migration URL.
# For local development, keep this equal to DATABASE_URL unless your machine can reliably reach
# the direct Supabase host. Using db.[PROJECT-REF].supabase.co can fail locally on IPv6-restricted networks.
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres?sslmode=require&connect_timeout=30

# Optional DIRECT_URL replacement only if your local network can reach the direct database host:
# DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require&connect_timeout=30

# If you intentionally use the transaction pooler on port 6543 for Prisma,
# add pgbouncer=true and connection_limit=1:
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require&connect_timeout=30

NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[YOUR_SUPABASE_ANON_KEY]
SUPABASE_SERVICE_ROLE_KEY=[YOUR_SUPABASE_SERVICE_ROLE_KEY]

SUPABASE_STORAGE_BUCKET=evidence-private
SENTRY_DSN=
SEED_HEAD_OF_PROCUREMENT_EMAIL=your-head-of-procurement-email@example.com
SEED_FINANCIAL_CONTROLLER_EMAIL=your-financial-controller-email@example.com
SEED_TACTICAL_BUYER_EMAIL=your-tactical-buyer-email@example.com
