# Traxium environment template
# Copy this file to `.env` for local development.
# The sample values below are structurally valid but must be replaced with your
# own Supabase project URLs, database URLs, and keys before running the app.

############################
# App environment
############################
# Allowed values: development, test, preview, production
APP_ENV=development

# Public base URL used in auth redirects, invitation links, and password recovery.
NEXT_PUBLIC_APP_URL=http://localhost:3000

############################
# Database / Prisma
############################
# Primary runtime URL. For local Supabase development, prefer the session pooler on port 5432.
DATABASE_URL=postgresql://postgres.localdev:localdev-password@aws-1-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require&connect_timeout=30

# Direct migration URL. Keep this equal to DATABASE_URL unless your network can reliably reach
# the direct `db.localdev.supabase.co` host.
DIRECT_URL=postgresql://postgres.localdev:localdev-password@aws-1-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require&connect_timeout=30

# Optional direct-host example only when your network can reach it:
# DIRECT_URL=postgresql://postgres:localdev-password@db.localdev.supabase.co:5432/postgres?sslmode=require&connect_timeout=30

# If you intentionally use the Supabase transaction pooler on port 6543, add pgbouncer settings:
# DATABASE_URL=postgresql://postgres.localdev:localdev-password@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require&connect_timeout=30

############################
# Supabase
############################
# Required in development, preview, and production.
NEXT_PUBLIC_SUPABASE_URL=https://localdev.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsInJlZiI6ImxvY2FsZGV2In0.sig
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwicmVmIjoibG9jYWxkZXYifQ.sig

# Private bucket for evidence uploads.
SUPABASE_STORAGE_BUCKET=evidence-private

############################
# Auth redirect notes
############################
# Configure these redirect URLs in Supabase Auth:
# - http://localhost:3000/invite/*
# - http://localhost:3000/reset-password
# Preview and production should point to the real host equivalents.

############################
# Billing / Stripe
############################
# Required when Stripe-backed billing flows are enabled.
STRIPE_SECRET_KEY=sk_test_localdevbillingsecretkey000000000000000000000000
STRIPE_WEBHOOK_SECRET=whsec_localdevbillingwebhooksecret000000000000000000000000
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/settings/billing
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/settings/billing?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/settings/billing?checkout=cancelled

# Hybrid catalog examples: one licensed recurring price plus one metered price per plan.
STRIPE_STARTER_PRODUCT_ID=prod_localdevstarter2026
STRIPE_STARTER_BASE_PRICE_ID=price_localdevstartermonthly2026
STRIPE_STARTER_METERED_PRICE_ID=price_localdevstarterusage2026
STRIPE_GROWTH_PRODUCT_ID=prod_localdevgrowth2026
STRIPE_GROWTH_BASE_PRICE_ID=price_localdevgrowthmonthly2026
STRIPE_GROWTH_METERED_PRICE_ID=price_localdevgrowthusage2026

############################
# Observability / Sentry
############################
# Optional server DSN for Node/Edge capture.
SENTRY_DSN=

# Optional client DSN for browser-side capture.
NEXT_PUBLIC_SENTRY_DSN=

############################
# Analytics
############################
# Optional public analytics transport used by browser-side capture.
NEXT_PUBLIC_ANALYTICS_HOST=
NEXT_PUBLIC_ANALYTICS_KEY=
NEXT_PUBLIC_ANALYTICS_CAPTURE_PATH=/capture
NEXT_PUBLIC_ANALYTICS_IDENTIFY_PATH=/identify

# Optional server overrides. If unset, server analytics falls back to the public host/key above.
ANALYTICS_HOST=
ANALYTICS_KEY=
ANALYTICS_CAPTURE_PATH=/capture
ANALYTICS_IDENTIFY_PATH=/identify

############################
# Async jobs / worker
############################
# Optional worker tuning.
JOB_WORKER_ONCE=false
JOB_WORKER_MAX_JOBS=100
JOB_WORKER_IDLE_DELAY_MS=2000

# Optional tenant/type filters for scoped job workers.
JOB_WORKER_ORGANIZATION_ID=
JOB_WORKER_TYPES=

############################
# Seed data
############################
SEED_HEAD_OF_PROCUREMENT_EMAIL=your-head-of-procurement-email@example.com
SEED_FINANCIAL_CONTROLLER_EMAIL=your-financial-controller-email@example.com
SEED_TACTICAL_BUYER_EMAIL=your-tactical-buyer-email@example.com

############################
# Test / local-only helpers
############################
# Keep disabled outside tests unless you intentionally want cache enabled in test-like runs.
ENABLE_SHORT_LIVED_CACHE_IN_TESTS=false
